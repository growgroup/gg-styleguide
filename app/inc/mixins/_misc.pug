//- サイト内で必要なコンポーネントを適宜追加・編集して使用

mixin c_relation(title,data)
  +c.relation(class=attributes.class)
    .l-container
      h3.c-heading.is-sm !{title}
      +e.buttons
        each itemData in data
          +e.button: +a(itemData.link).c-button.is-xlg.is-primary.js-current-nav !{itemData.title}

mixin c_anchor-nav(data)
  +c.anchor-nav(class=attributes.class)
    +e.buttons
      each itemData in data
        +e.button: +a(itemData.link).c-button.is-nav.js-anchor !{itemData.title}

mixin c_news__block(data)
  -
    if (typeof data === "undefined") {
      var data = [
        {
          url: "/news/category/page/",
          date: "2022.01.01",
          label: "カテゴリ",
          title: "お知らせの投稿タイトルがここに入ります。お知らせの投稿タイトルがここに入ります。お知らせの投稿タイトルがここに入ります。",
          icon: "arrow_forward",
        }
      ]
    }
  //- デザインに合わせて変更OK。WordPressでは「リンク無し」「外部リンク」「ファイルリンク」が発生することに注意
  each item in data
    +ae(item.url).block
      +e.block-content
        +e.block-date !{item.date}
        if item.label
          +e.block-label.c-label !{item.label}
        +e.block-text-wrap
          +e.block-text !{item.title}
          if item.excerpt
            +e.block-excerpt !{item.excerpt}
      //-item.iconがあれば .c-icon-fontを追加、+span.block-label-file を追加
      if item.fileType
        +e.block-icon
          +span.block-icon-file(class=item.fileClass) !{item.fileType}
      else if item.icon
        +e.block-icon
          span.c-icon-font !{item.icon}

mixin select-prefectures(optgroup=false)
  -
    //- select-prefectures(optgroup=true) の場合は地域ごとにグループ表示
    prefecturesList = [
      { label: "北海道・東北", prefectures: ["北海道", "青森県", "岩手県", "宮城県", "秋田県", "山形県", "福島県"] },
      { label: "関東", prefectures: ["茨城県", "栃木県", "群馬県", "埼玉県", "千葉県", "東京都", "神奈川県"] },
      { label: "北陸・甲信", prefectures: ["新潟県", "富山県", "石川県", "福井県", "山梨県", "長野県"] },
      { label: "東海・関西", prefectures: ["岐阜県", "静岡県", "愛知県", "三重県", "滋賀県", "京都府", "大阪府", "兵庫県", "奈良県", "和歌山県"] },
      { label: "中国・四国", prefectures: ["鳥取県", "島根県", "岡山県", "広島県", "山口県", "徳島県", "香川県", "愛媛県", "高知県"] },
      { label: "九州・沖縄", prefectures: ["福岡県", "佐賀県", "長崎県", "熊本県", "大分県", "宮崎県", "鹿児島県", "沖縄県"] }
    ]

  select(name="都道府県")
    option(disabled,selected) 選択してください
    if optgroup
      each group in prefecturesList
        optgroup(label=group.label)
          each prefecture in group.prefectures
            option(value=prefecture)= prefecture
    else
      each group in prefecturesList
        each prefecture in group.prefectures
          option(value=prefecture)= prefecture



mixin select-nums(name="age", start=18, end=50,selected="選択してください", unit)
  select(name=name)&attributes(attributes)
    option(disabled,selected) !{selected}
    - for (let i = start; i <= end; i++)
      <option value="#{i}">#{i}#{unit || ""}</option>

