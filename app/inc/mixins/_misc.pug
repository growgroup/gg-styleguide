//- img タグ
mixin img(file,alt,width,height)
  -
    src = setSrcValue(file, "/assets/images/")
  -
    if ( typeof alt === "undefined" ){
    var alt = ""
    }
  img(src=src, alt!=alt, width!=width, height!=height)&attributes(attributes)

//- picture タグ
//-+picture("img-sample-pc.jpg", "img-sample-sp.jpg","text", 1920, 1080, 750, 750)
//-PC/SPでaspect比共通ならSP用のwidthとheightは不要
mixin picture(opts)
  -
    opts = opts || {}
    var pc = opts.pc || "",
      sp = opts.sp || "",
      alt = opts.alt || "",
      width = opts.width || null,
      height = opts.height || null,
      widthSp = opts.widthSp || null,
      heightSp = opts.heightSp || null,
      media = opts.media || "",
      fetchpriority = opts.fetchpriority || null

  -
    pc = setSrcValue(pc, "/assets/images/")
    sp = setSrcValue(sp, "/assets/images/")

  -
    if (!media || media === "") {
      media = '(width < 46.875em)'
    } else if (media === "medium") {
      media = '(width < 59.375em)'
    }

  picture&attributes(attributes)
    source(
      srcset=sp
      media!=media
      width!=widthSp
      height!=heightSp
    )
    img(
      src=pc
      alt=alt
      width!=width
      height!=height
      fetchpriority!=fetchpriority
    )

//- video タグ
mixin video(file)
  -
    file = setSrcValue(file, "/assets/files/")
  video(src=file)&attributes(attributes)

//- 背景画像
mixin bgimg(file)
  -
    file = setSrcValue(file, "/assets/images/")
  div(style="background-image: url(" + file + ")")&attributes(attributes)
    block

//- ループ
//- +loop(10)
//-   p ここにループするコンテンツ
mixin loop(count)
  - var n = 0
  while n < count
    block
    - n++

//- スクローラブルブロック（スクロールヒント）
mixin c_scrollable
  //- scroll-hint が .js-scrollableの親の要素に対して適用されるため
  //- c-scrollableと .js-scrollableを分けることを推奨
  .c-scrollable&attributes(attributes)
    .js-scrollable
      block

//- 投稿ページナビゲーション
mixin c_post_nav(listID)
  -
    if (typeof listID === "undefined") {
      var listID = "news"
    }
    var path = config.rootpath + "/" + listID + "/";
  nav.c-post-navs
    ul
      li.c-post-navs__prev: +a(path +"page/").c-button.is-sm.is-arrow-left 前の記事へ
      li.c-post-navs__archive: +a(path).c-button.is-sm <span class="c-icon-font">list</span>記事一覧へ
      li.c-post-navs__next: +a(path+"page/").c-button.is-sm 次の記事へ

//- table row
mixin tr(th, td)
  tr&attributes(attributes)
    th!= th
    td!= td

mixin c_relation(title,data)
  +c.relation(class=attributes.class)
    .l-container
      +e.title.c-heading.is-sm.is-center !{title}
      +e.buttons
        each itemData in data
          +e.button: +a(itemData.link).c-button.is-xlg.is-primary.js-current-nav !{itemData.title}

mixin c_anchor-nav(data)
  +c.anchor-nav(class=attributes.class)
    +e.buttons
      each itemData in data
        +e.button: +a(itemData.link).c-button.is-nav.js-anchor !{itemData.title}

mixin c_news__block(data)
  -
    if (typeof data === "undefined") {
      var data = [
        {
          url: "/news/category/page/",
          date: "2022.01.01",
          label: "カテゴリ",
          title: "お知らせの投稿タイトルがここに入ります。お知らせの投稿タイトルがここに入ります。お知らせの投稿タイトルがここに入ります。",
          icon: "arrow_forward",
        }
      ]
    }
  each item in data
    +ae(item.url).block
      +e.block-content
        +e.block-date !{item.date}
        if item.label
          +e.block-label.c-label !{item.label}
        +e.block-text-wrap
          +e.block-text !{item.title}
          if item.excerpt
            +e.block-excerpt !{item.excerpt}
      //-item.iconがあれば .c-icon-fontを追加、+span.block-label-file を追加
      if item.fileType
        +e.block-icon
          +span.block-icon-file(class=item.fileClass) !{item.fileType}
      else if item.icon
        +e.block-icon
          span.c-icon-font !{item.icon}

mixin select-prefectures(optgroup=false)
  -
    //- select-prefectures(optgroup=true) の場合は地域ごとにグループ表示
    prefecturesList = [
      { label: "北海道・東北", prefectures: ["北海道", "青森県", "岩手県", "宮城県", "秋田県", "山形県", "福島県"] },
      { label: "関東", prefectures: ["茨城県", "栃木県", "群馬県", "埼玉県", "千葉県", "東京都", "神奈川県"] },
      { label: "北陸・甲信", prefectures: ["新潟県", "富山県", "石川県", "福井県", "山梨県", "長野県"] },
      { label: "東海・関西", prefectures: ["岐阜県", "静岡県", "愛知県", "三重県", "滋賀県", "京都府", "大阪府", "兵庫県", "奈良県", "和歌山県"] },
      { label: "中国・四国", prefectures: ["鳥取県", "島根県", "岡山県", "広島県", "山口県", "徳島県", "香川県", "愛媛県", "高知県"] },
      { label: "九州・沖縄", prefectures: ["福岡県", "佐賀県", "長崎県", "熊本県", "大分県", "宮崎県", "鹿児島県", "沖縄県"] }
    ]

  select(name="都道府県")
    option(disabled,selected) 選択してください
    if optgroup
      each group in prefecturesList
        optgroup(label=group.label)
          each prefecture in group.prefectures
            option(value=prefecture)= prefecture
    else
      each group in prefecturesList
        each prefecture in group.prefectures
          option(value=prefecture)= prefecture



mixin select-nums(name="age", start=18, end=50,selected="選択してください", unit)
  select(name=name)&attributes(attributes)
    option(disabled,selected) !{selected}
    - for (let i = start; i <= end; i++)
      <option value="#{i}#{unit || ''}">#{i}#{unit || ''}</option>

mixin c_cookie
  +c.block-cookie.js-cookie#cookie
    .l-container
      +e.inner
        +e("p").text
          | 本ウェブサイトでは、お客様の利便性の向上及びサービスの品質維持・向上を目的として、Cookieを使用しています。<br />
          | 本ウェブサイトの閲覧を続行した場合は、Cookieの使用に同意したものとします。
        +e.button: +a("#")#wt-cli-accept-all-btn 同意する

mixin link(href)
  link(href=config.rootpath + href)&attributes(attributes)

mixin script(src)
  script(src=config.rootpath + src)&attributes(attributes)
