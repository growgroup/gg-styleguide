{
  "excludeFiles": [
    "./dist/format/*.html",
    "./dist/design-format/*.html"
  ],
  "rules": {
    "attr-duplication": true,
    "deprecated-attr": true,
    "deprecated-element": true,
    "doctype": "always",
    "end-tag": true,
    "heading-levels": {
      "severity": "warning"
    },
    "id-duplication": true,
    "invalid-attr": true,
    "label-has-control": {
      "severity": "warning"
    },
    "no-orphaned-end-tag": true,
    "permitted-contents": true,
    "required-element": true,
    "require-datetime": true,
    "required-attr": true,
    "required-h1": true,
    "table-row-column-alignment": true
  },
  "nodeRules": [
    {
      "selector": "meta[property]",
      "rules": {
        "invalid-attr": {
          "options": {
            "allowAttrs": ["property", "content"]
          }
        }
      }
    },
    {
      "selector": "meta",
      "rules": {
        "required-attr": false
      }
    },
    {
      "selector": "iframe",
      "rules": {
        "invalid-attr": false,
        "required-attr": false,
        "deprecated-attr": false
      }
    },
    {
      "selector": ".fb-like",
      "rules": {
        "invalid-attr": false,
        "required-attr": false,
        "deprecated-attr": false
      }
    },
    {
      "selector": ".l-main img",
      "rules": {
        "invalid-attr": {
          "options": {
            "disallowAttrs": [
              "class"
            ]
          },
          "severity": "warning",
          "reason": "WordPress案件では .l-main内で imgに直接classをつけず親要素にclassをつけてください。"
        }
      }
    },
    {
      "selector": "table",
      "rules": {
        "required-element": {
          "value": ["tbody"],
          "options": {
            "ignoreOmittedElements": true
          },
          "severity": "warning",
          "reason": "WordPress案件ではtable要素でtbody要素を省略できません。"
        }
      }
    }
  ],
  "childNodeRules": [
    {
      "selector": "svg",
      "inheritance": true,
      "rules": {
        "invalid-attr": false,
        "id-duplication": false,
        "required-attr": false
      }
    }
  ]
}
